{
  "name": "@draco-china/shadcn-pro",
  "version": "1.12.8",
  "description": "Pro components for shadcn/ui — Formily forms, TanStack tables, and more",
  "type": "module",
  "bin": {
    "shadcn-pro": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "dev": "turbo dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo typecheck",
    "release": "bun run --cwd packages/cli build && semantic-release",
    "prepare": "lefthook install",
    "gen:meta": "bun scripts/gen-docs-meta.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "picocolors": "^1.1.1",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "lefthook": "^2.1.8",
    "semantic-release": "^25.0.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "bun@1.3.14"
}
