{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "suspicious": {
        "noDuplicateCustomProperties": "off",
        "noArrayIndexKey": "warn"
      },
      "a11y": {
        "noSvgWithoutTitle": "warn",
        "useSemanticElements": "warn",
        "useFocusableInteractive": "warn",
        "useKeyWithClickEvents": "warn",
        "noRedundantRoles": "warn",
        "useAriaPropsForRole": "warn",
        "useIframeTitle": "warn",
        "noLabelWithoutControl": "warn",
        "useButtonType": "warn"
      },
      "complexity": {
        "noImportantStyles": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "cssModules": false,
      "allowWrongLineComments": false,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/dist",
      "!**/out",
      "!**/.source",
      "!**/apps/docs/registry",
      "!**/apps/docs/styles",
      "!**/apps/docs/lib/__blocks-generated__.ts",
      "!**/*.lockb",
      "!**/view/blocks"
    ]
  }
}
